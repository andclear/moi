{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://moi.local/schemas/character-card-v3.schema.json",
  "title": "SillyTavern Character Card V3 Schema",
  "description": "基于 docs/SillyTavern角色卡完整字段文档.md 冻结的 Character Card V3 JSON Schema。Schema 定义 SillyTavern 可读取和设置的核心字段，并允许保留生态插件产生的未知扩展字段。",
  "type": "object",
  "additionalProperties": true,
  "required": ["name", "description", "first_mes", "spec", "spec_version", "data"],
  "properties": {
    "name": {
      "type": "string",
      "description": "角色名称。"
    },
    "description": {
      "type": "string",
      "description": "角色描述，通常对应角色定义或人设描述。"
    },
    "personality": {
      "type": "string",
      "default": "",
      "description": "角色性格简述。"
    },
    "scenario": {
      "type": "string",
      "default": "",
      "description": "场景或背景描述。"
    },
    "first_mes": {
      "type": "string",
      "description": "第一条消息，即默认开场白。"
    },
    "mes_example": {
      "type": "string",
      "default": "",
      "description": "对话示例。"
    },
    "creatorcomment": {
      "type": "string",
      "default": "",
      "description": "创作者备注，通常等同于 data.creator_notes。"
    },
    "avatar": {
      "type": "string",
      "default": "none",
      "description": "头像文件名或唯一标识符。"
    },
    "talkativeness": {
      "$ref": "#/$defs/talkativeness"
    },
    "fav": {
      "oneOf": [
        {
          "type": "boolean"
        },
        {
          "type": "string"
        }
      ],
      "default": false,
      "description": "是否收藏。"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": [],
      "description": "标签列表。"
    },
    "spec": {
      "type": "string",
      "const": "chara_card_v3",
      "description": "角色卡规范标识。"
    },
    "spec_version": {
      "type": "string",
      "const": "3.0",
      "description": "角色卡规范版本号。"
    },
    "create_date": {
      "type": "string",
      "description": "创建日期，SillyTavern 常用可读时间字符串。"
    },
    "data": {
      "$ref": "#/$defs/character_data"
    }
  },
  "$defs": {
    "talkativeness": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      ],
      "default": "0.5",
      "description": "健谈度，通常为 0 到 1。"
    },
    "character_data": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "description", "first_mes"],
      "properties": {
        "name": {
          "type": "string",
          "description": "角色名称。"
        },
        "description": {
          "type": "string",
          "description": "角色描述。"
        },
        "personality": {
          "type": "string",
          "default": "",
          "description": "角色性格。"
        },
        "scenario": {
          "type": "string",
          "default": "",
          "description": "场景描述。"
        },
        "first_mes": {
          "type": "string",
          "description": "第一条消息。"
        },
        "mes_example": {
          "type": "string",
          "default": "",
          "description": "对话示例。"
        },
        "creator_notes": {
          "type": "string",
          "default": "",
          "description": "创作者备注。"
        },
        "system_prompt": {
          "type": "string",
          "default": "",
          "description": "系统提示词。"
        },
        "post_history_instructions": {
          "type": "string",
          "default": "",
          "description": "历史后指令，也可作为作者注释。"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "标签列表。"
        },
        "creator": {
          "type": "string",
          "default": "",
          "description": "创作者名称。"
        },
        "character_version": {
          "type": "string",
          "default": "",
          "description": "角色版本号。"
        },
        "alternate_greetings": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "备选开场白列表。"
        },
        "character_book": {
          "$ref": "#/$defs/character_book"
        },
        "extensions": {
          "$ref": "#/$defs/character_extensions"
        },
        "group_only_greetings": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "deprecated": true,
          "description": "仅群组可用的开场白，当前 SillyTavern 已废弃。"
        }
      }
    },
    "character_extensions": {
      "type": "object",
      "additionalProperties": true,
      "description": "角色扩展字段。必须保留未知字段，避免破坏第三方插件配置。",
      "properties": {
        "talkativeness": {
          "$ref": "#/$defs/talkativeness"
        },
        "fav": {
          "type": "boolean",
          "default": false,
          "description": "是否收藏。"
        },
        "world": {
          "type": "string",
          "default": "",
          "description": "绑定的外部世界书名称。"
        },
        "depth_prompt": {
          "$ref": "#/$defs/depth_prompt"
        },
        "regex_scripts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/regex_script"
          },
          "default": [],
          "description": "角色局部正则脚本列表。"
        },
        "pygmalion_id": {
          "type": "string"
        },
        "github_repo": {
          "type": "string"
        },
        "source_url": {
          "type": "string"
        },
        "chub": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "full_path": {
              "type": "string"
            }
          }
        },
        "risuai": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "source": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "sd_character_prompt": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "positive": {
              "type": "string"
            },
            "negative": {
              "type": "string"
            }
          }
        },
        "tavern_helper": {
          "type": "array",
          "items": true
        }
      }
    },
    "depth_prompt": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "prompt": {
          "type": "string",
          "default": ""
        },
        "depth": {
          "type": "number",
          "default": 4
        },
        "role": {
          "type": "string",
          "enum": ["system", "user", "assistant"],
          "default": "system"
        }
      }
    },
    "character_book": {
      "type": "object",
      "additionalProperties": true,
      "required": ["extensions", "entries"],
      "properties": {
        "name": {
          "type": "string",
          "default": "",
          "description": "世界书名称。"
        },
        "description": {
          "type": "string",
          "default": "",
          "description": "世界书描述。"
        },
        "scan_depth": {
          "type": "number",
          "description": "扫描深度。"
        },
        "token_budget": {
          "type": "number",
          "description": "Token 预算上限。"
        },
        "recursive_scanning": {
          "type": "boolean",
          "description": "是否启用递归扫描。"
        },
        "extensions": {
          "type": "object",
          "additionalProperties": true,
          "default": {},
          "description": "世界书扩展字段。"
        },
        "entries": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/world_info_entry"
          },
          "default": [],
          "description": "世界书条目列表。"
        }
      }
    },
    "world_info_entry": {
      "type": "object",
      "additionalProperties": true,
      "required": ["content"],
      "properties": {
        "uid": {
          "type": "number",
          "description": "运行时条目唯一标识符。"
        },
        "id": {
          "type": "number",
          "description": "导入或导出时可能出现的条目唯一标识符。"
        },
        "key": {
          "$ref": "#/$defs/string_array"
        },
        "keys": {
          "$ref": "#/$defs/string_array"
        },
        "keysecondary": {
          "$ref": "#/$defs/string_array"
        },
        "secondary_keys": {
          "$ref": "#/$defs/string_array"
        },
        "comment": {
          "type": "string",
          "default": "",
          "description": "条目标题或编辑备注。"
        },
        "content": {
          "type": "string",
          "description": "条目内容，插入到提示词中。"
        },
        "constant": {
          "type": "boolean",
          "default": false,
          "description": "是否始终激活。"
        },
        "vectorized": {
          "type": "boolean",
          "default": false,
          "description": "是否向量化。"
        },
        "selective": {
          "type": "boolean",
          "default": true,
          "description": "是否需要关键词匹配。"
        },
        "selectiveLogic": {
          "$ref": "#/$defs/selective_logic"
        },
        "order": {
          "type": "number",
          "description": "运行时插入顺序。"
        },
        "insertion_order": {
          "type": "number",
          "description": "导入或导出时可能出现的插入顺序。"
        },
        "position": {
          "oneOf": [
            {
              "$ref": "#/$defs/world_position"
            },
            {
              "type": "string"
            }
          ],
          "description": "插入位置。当前主流为数字枚举，旧数据可能是字符串。"
        },
        "disable": {
          "type": "boolean",
          "description": "运行时是否禁用。"
        },
        "enabled": {
          "type": "boolean",
          "description": "导入或导出时可能出现的启用状态。"
        },
        "addMemo": {
          "type": "boolean",
          "description": "运行时备注追踪字段，不建议持久化。"
        },
        "use_regex": {
          "type": "boolean",
          "description": "关键词是否按正则匹配。"
        },
        "extensions": {
          "$ref": "#/$defs/world_info_entry_extensions"
        }
      },
      "anyOf": [
        {
          "required": ["key"]
        },
        {
          "required": ["keys"]
        }
      ]
    },
    "world_info_entry_extensions": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "position": {
          "$ref": "#/$defs/world_position",
          "default": 4
        },
        "depth": {
          "type": "number",
          "default": 4,
          "description": "插入深度。"
        },
        "role": {
          "$ref": "#/$defs/world_role"
        },
        "display_index": {
          "type": "number",
          "description": "显示排序索引。"
        },
        "selectiveLogic": {
          "$ref": "#/$defs/selective_logic"
        },
        "probability": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "default": 100,
          "description": "激活概率。"
        },
        "useProbability": {
          "type": "boolean",
          "default": true,
          "description": "是否启用概率判断。"
        },
        "scan_depth": {
          "$ref": "#/$defs/nullable_number"
        },
        "case_sensitive": {
          "$ref": "#/$defs/nullable_boolean"
        },
        "match_whole_words": {
          "$ref": "#/$defs/nullable_boolean"
        },
        "exclude_recursion": {
          "type": "boolean",
          "default": false
        },
        "prevent_recursion": {
          "type": "boolean",
          "default": false
        },
        "delay_until_recursion": {
          "oneOf": [
            {
              "type": "boolean"
            },
            {
              "type": "number"
            }
          ],
          "default": false
        },
        "group": {
          "type": "string",
          "default": ""
        },
        "group_override": {
          "type": "boolean",
          "default": false
        },
        "group_weight": {
          "type": "number",
          "default": 100
        },
        "use_group_scoring": {
          "type": "boolean",
          "default": false
        },
        "sticky": {
          "$ref": "#/$defs/nullable_number"
        },
        "cooldown": {
          "$ref": "#/$defs/nullable_number"
        },
        "delay": {
          "$ref": "#/$defs/nullable_number"
        },
        "match_persona_description": {
          "type": "boolean",
          "default": false
        },
        "match_character_description": {
          "type": "boolean",
          "default": false
        },
        "match_character_personality": {
          "type": "boolean",
          "default": false
        },
        "match_character_depth_prompt": {
          "type": "boolean",
          "default": false
        },
        "match_scenario": {
          "type": "boolean",
          "default": false
        },
        "match_creator_notes": {
          "type": "boolean",
          "default": false
        },
        "automation_id": {
          "type": "string",
          "default": ""
        },
        "vectorized": {
          "type": "boolean",
          "default": false
        },
        "triggers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/world_trigger"
          },
          "default": []
        },
        "ignore_budget": {
          "type": "boolean",
          "default": false
        },
        "outlet_name": {
          "type": "string",
          "default": ""
        }
      }
    },
    "regex_script": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "scriptName", "findRegex", "replaceString"],
      "properties": {
        "id": {
          "type": "string",
          "description": "脚本唯一标识符。"
        },
        "scriptName": {
          "type": "string",
          "description": "脚本名称。"
        },
        "findRegex": {
          "type": "string",
          "description": "查找正则表达式。"
        },
        "replaceString": {
          "type": "string",
          "description": "替换字符串。"
        },
        "disabled": {
          "type": "boolean",
          "default": false
        },
        "placement": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/regex_placement"
          },
          "default": [1, 2],
          "description": "正则应用位置。"
        },
        "markdownOnly": {
          "type": "boolean",
          "default": false
        },
        "promptOnly": {
          "type": "boolean",
          "default": false
        },
        "runOnEdit": {
          "type": "boolean",
          "default": true
        },
        "minDepth": {
          "$ref": "#/$defs/nullable_number"
        },
        "maxDepth": {
          "$ref": "#/$defs/nullable_number"
        },
        "trimStrings": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "substituteRegex": {
          "type": "number",
          "enum": [0, 1, 2],
          "default": 0
        }
      }
    },
    "string_array": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "nullable_number": {
      "oneOf": [
        {
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "nullable_boolean": {
      "oneOf": [
        {
          "type": "boolean"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "selective_logic": {
      "type": "number",
      "enum": [0, 1, 2, 3],
      "default": 0,
      "description": "次要关键词逻辑：0=AND_ANY，1=NOT_ALL，2=NOT_ANY，3=AND_ALL。"
    },
    "world_position": {
      "type": "number",
      "enum": [0, 1, 2, 3, 4, 5, 6, 7],
      "default": 4,
      "description": "世界书插入位置。"
    },
    "world_role": {
      "type": "number",
      "enum": [0, 1, 2],
      "default": 0,
      "description": "世界书插入角色：0=system，1=user，2=assistant。"
    },
    "world_trigger": {
      "type": "string",
      "enum": ["normal", "continue", "impersonate", "swipe", "regenerate", "quiet"]
    },
    "regex_placement": {
      "type": "number",
      "enum": [0, 1, 2, 3, 5, 6],
      "description": "正则脚本作用范围。"
    }
  }
}
