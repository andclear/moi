{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://echo.local/schemas/character-card-v3.example.schema.json",
  "title": "Character Card V3 示例 Schema",
  "description": "这是 Character Card V3 最终结构的格式示例。正式结构使用 JSON Schema 描述字段、类型、必填项、枚举、嵌套对象和扩展字段。实际开发时会根据正式 schema 生成 Zod 校验与导出构建逻辑。",
  "type": "object",
  "additionalProperties": false,
  "required": ["spec", "spec_version", "data"],
  "properties": {
    "spec": {
      "type": "string",
      "const": "chara_card_v3",
      "description": "角色卡规范标识。正式值以你提供的 Character Card V3 规范为准。"
    },
    "spec_version": {
      "type": "string",
      "examples": ["3.0"],
      "description": "角色卡规范版本。"
    },
    "data": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "description", "personality", "scenario", "first_mes", "mes_example", "extensions"],
      "properties": {
        "name": {
          "type": "string",
          "description": "角色名称。"
        },
        "description": {
          "type": "string",
          "description": "角色核心描述，可由角色档案 Markdown 汇总生成。"
        },
        "personality": {
          "type": "string",
          "description": "人格、行为准则、核心矛盾和说话风格。"
        },
        "scenario": {
          "type": "string",
          "description": "角色所处场景、世界背景和用户进入故事时的上下文。"
        },
        "first_mes": {
          "type": "string",
          "description": "默认开场白。"
        },
        "mes_example": {
          "type": "string",
          "description": "示例对话。"
        },
        "creator_notes": {
          "type": "string",
          "description": "创作者备注、版本说明或使用说明。"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "可选标签。第一阶段不做标签管理，但导出结构可保留。"
        },
        "worldbook": {
          "type": "object",
          "additionalProperties": false,
          "description": "世界书内容。最终会和其他角色卡内容一起写入同一个 JSON 文件。",
          "required": ["entries"],
          "properties": {
            "entries": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/worldbook_entry"
              }
            }
          }
        },
        "greetings": {
          "type": "array",
          "description": "不同身份或场景下的开场白候选。默认开场白仍写入 first_mes。",
          "items": {
            "$ref": "#/$defs/greeting"
          }
        },
        "trial_runs": {
          "type": "array",
          "description": "终审对话历史摘要，用于后续编辑和复盘。是否进入最终正式规范由你提供的 schema 决定。",
          "items": {
            "$ref": "#/$defs/trial_run"
          }
        },
        "extensions": {
          "type": "object",
          "description": "Echo 自有扩展区，用于保存本项目需要但规范未覆盖的数据。",
          "additionalProperties": true,
          "properties": {
            "echo": {
              "$ref": "#/$defs/echo_extension"
            }
          }
        }
      }
    }
  },
  "$defs": {
    "worldbook_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "content"],
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "content": {
          "type": "string"
        },
        "keywords": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "greeting": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "identity", "content", "selected"],
      "properties": {
        "id": {
          "type": "string"
        },
        "identity": {
          "type": "string",
          "description": "用户身份，例如陌生人、委托人、老友、敌人。"
        },
        "content": {
          "type": "string"
        },
        "selected": {
          "type": "boolean"
        }
      }
    },
    "trial_run": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "mode", "summary"],
      "properties": {
        "id": {
          "type": "string"
        },
        "mode": {
          "type": "string",
          "enum": ["multi_interviewer_dialogue", "stress_test", "diary_dialogue"]
        },
        "summary": {
          "type": "string"
        },
        "ooc_risk": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        }
      }
    },
    "echo_extension": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "dossier_markdown": {
          "type": "string",
          "description": "Echo 内部使用的角色档案 Markdown。"
        },
        "dossier_metadata": {
          "type": "array",
          "description": "Markdown 块级元数据，记录 AI 推测、用户确认事实和锁定状态。",
          "items": {
            "$ref": "#/$defs/dossier_block_meta"
          }
        },
        "exported_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "dossier_block_meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["block_id", "source", "locked"],
      "properties": {
        "block_id": {
          "type": "string"
        },
        "source": {
          "type": "string",
          "enum": ["ai_inferred", "user_confirmed"]
        },
        "locked": {
          "type": "boolean"
        },
        "updated_by_generation_id": {
          "type": "string"
        }
      }
    }
  }
}
