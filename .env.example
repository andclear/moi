# Neon PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# 项目方预置 API 渠道，服务端使用，不能加 VITE_ 前缀
PRESET_API_BASE_URL="https://api.example.com/v1"
PRESET_API_KEY="sk-your-preset-key"
PRESET_MODEL="your-preset-model"

# 后台管理
ADMIN_PASSWORD_HASH="填入后台登录密码的 SHA-256 哈希"
ADMIN_SESSION_TOKEN="填入一段足够长的随机后台会话令牌"
