# Neon PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# 项目方预置 API 渠道，服务端使用，不能加 VITE_ 前缀
PRESET_API_BASE_URL="https://api.example.com/v1"
PRESET_API_KEY="sk-your-preset-key"
PRESET_MODEL="your-preset-model"

# 后台管理
ADMIN_PASSWORD_HASH=""
ADMIN_SESSION_TOKEN=""

# 用户自配 API 渠道默认占位，前端设置页仍以 IndexedDB 保存用户实际配置
VITE_CUSTOM_API_BASE_URL=""
VITE_CUSTOM_API_KEY=""
VITE_CUSTOM_MODEL=""
